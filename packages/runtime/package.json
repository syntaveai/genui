{
  "name": "@syntave/runtime",
  "version": "0.0.2",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/syntaveai/genui.git",
    "directory": "packages/runtime"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.tsx src/server.ts --format esm,cjs --dts --external react --external react-dom --external @syntave/ui",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint ok'",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.4.0",
    "@types/react": "^19.0.0"
  }
}
